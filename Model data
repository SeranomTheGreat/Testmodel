ressing Shift+Enter) will list all files under the input directory\n\nimport os\nfor dirname, _, filenames in os.walk('/kaggle/input'):\n    for filename in filenames:\n        print(os.path.join(dirname, filename))\n\n# You can write up to 20GB to the current directory (/kaggle/working/) that gets preserved as output when you create a version using \"Save & Run All\" \n# You can also write temporary files to /kaggle/temp/, but they won't be saved outside of the current session","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport glob\nimport shutil\nfrom PIL import Image\nimport concurrent.futures\n\n# --- Configuration ---\nINPUT_DIR = \"/kaggle/input\"\nWORKING_DIR = \"/kaggle/working/fast_dataset\"\nZIP_PATH = \"/kaggle/working/optimized_plant_data\" # Will automatically add .zip\nTARGET_SIZE = (224, 224)\n\nprint(\"🔍 Step 1: Scanning for images...\")\n# Find all images\nexts = ('*.jpg', '*.jpeg', '*.png', '*.JPG', '*.JPEG', '*.PNG')\nimage_paths = []\nfor ext in exts:\n    for path in glob.iglob(os.path.join(INPUT_DIR, '**', ext), recursive=True):\n        image_paths.append(path)\n\nprint(f\"✅ Found {len(image_paths)} total images.\")\n\n# Create the base working directory\nif os.path.exists(WORKING_DIR):\n    shutil.rmtree(WORKING_DIR)\nos.makedirs(WORKING_DIR)\n\n# --- Processing Function ---\ndef process_and_save_image(file_path):\n    try:\n        # The class name is the folder name the image is currently in\n        class_name = os.path.basename(os.path.dirname(file_path))\n        file_name = os.path.basename(file_path)\n        \n        # Create the class folder in our new optimized directory\n        class_dir = os.path.join(WORKING_DIR, class_name)\n        os.makedirs(class_dir, exist_ok=True)\n        \n        # Open, convert to standard RGB, resize, and save\n        with Image.open(file_path) as img:\n            img = img.convert('RGB')\n            img = img.resize(TARGET_SIZE, Image.Resampling.BILINEAR)\n            \n            # Save as high-quality JPEG to save massive amounts of disk space\n            save_path = os.path.join(class_dir, f\"{os.path.splitext(file_name)[0]}.jpg\")\n            img.save(save_path, format=\"JPEG\", quality=90)\n            \n        return True\n    except Exception as e:\n        # Skips corrupted or unreadable images automatically\n        return False\n\n# --- Multi-Core Processing ---\nprint(f\"🚀 Step 2: Resizing and organizing images using all CPU cores...\")\nsuccess_count = 0\nfail_count = 0\n\n# Use all available CPU cores\nwith concurrent.futures.ProcessPoolExecutor() as executor:\n    # Map the function to all image paths\n    results = executor.map(process_and_save_image, image_paths)\n    \n    for i, success in enumerate(results):\n        if success:\n            success_count += 1\n        else:\n            fail_count += 1\n            \n        # Print progress every 5000 images so you know it hasn't frozen\n        if (i + 1) % 5000 == 0:\n            print(f\"   ...Processed {i + 1} / {len(image_paths)} images...\")\n\nprint(f\"✅ Processing complete! Successfully resized: {success_count} | Failed/Corrupted: {fail_count}\")\n\n# --- Zipping ---\nprint(\"📦 Step 3: Packing everything into a single, high-speed ZIP file...\")\nshutil.make_archive(ZIP_PATH, 'zip', WORKING_DIR)\n\n# Clean up the unzipped folder to save Kaggle disk space\nshutil.rmtree(WORKING_DIR)\n\nprint(f\"🎉 ALL DONE! Your optimized dataset is saved at: {ZIP_PATH}.zip\")\nprint(f\"File size: {os.path.getsize(ZIP_PATH + '.zip') / (1024*1024):.2f} MB\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-17T04:11:39.211380Z","iopub.execute_input":"2026-05-17T04:11:39.211724Z","iopub.status.idle":"2026-05-17T06:08:43.316223Z","shell.execute_reply.started":"2026-05-17T04:11:39.211692Z","shell.execute_reply":"2026-05-17T06:08:43.314235Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# 1. Fix Kaggle environment conflicts and install libraries\n!pip uninstall -y tensorflow && pip install tensorflow-cpu\n!pip install -q timm torchmetrics torchvision scikit-learn\n\nimport os\nimport glob\nfrom collections import Counter\nimport random\nimport numpy as np\nfrom PIL import Image\n\n# Modern TPU v5e PJRT Configuration\nos.environ[\"PJRT_DEVICE\"] = \"TPU\"\n\nimport torch\nimport torch.nn as nn\nimport torch.optim as optim\nfrom torch.utils.data import Dataset, DataLoader\nimport torchvision.transforms.v2 as v2\nimport timm\nfrom sklearn.model_selection import train_test_split\n\n# PyTorch XLA imports\nimport torch_xla.core.xla_model as xm\nimport torch_xla.distributed.parallel_loader as pl\nimport torch_xla.distributed.xla_multiprocessing as xmp\n\nprint(\"✅ Libraries installed and environment configured!\")\n\n# ==========================================\n# CONFIGURATION\n# ==========================================\nclass TPUConfig:\n    NUM_CORES = 8\n    GLOBAL_BATCH_SIZE = 256 \n    BATCH_SIZE_PER_CORE = GLOBAL_BATCH_SIZE // NUM_CORES \n    IMAGE_SIZE = 224 # Images are already this size, so loading is instant!\n    SEED = 42\n    \n    EPOCHS_PHASE_1 = 3   \n    EPOCHS_PHASE_2 = 22  \n    TOTAL_EPOCHS = EPOCHS_PHASE_1 + EPOCHS_PHASE_2\n    \n    BASE_LR = 1e-3\n    SCALED_LR = BASE_LR * (GLOBAL_BATCH_SIZE / 256.0) \n    WEIGHT_DECAY = 1e-2\n    MAX_GRAD_NORM = 1.0\n    LABEL_SMOOTHING = 0.1\n    \n    # ⚠️ IMPORTANT: Change this to the exact name of your NEW dataset folder!\n    # You can find the exact path by clicking the \"copy file path\" icon next to your dataset on the right panel.\n    INPUT_DIR = \"/kaggle/input/my-optimized-plant-data\" \n    \n    CHECKPOINT_DIR = \"/kaggle/working/checkpoints\"\n    os.makedirs(CHECKPOINT_DIR, exist_ok=True)\n    \n    NUM_CLASSES = None\n    CLASS_NAMES = None\n    CLASS_WEIGHTS = None\n\ndef seed_everything(seed):\n    random.seed(seed)\n    np.random.seed(seed)\n    torch.manual_seed(seed)\n\n# ==========================================\n# FAST DATA SCANNER (For Pre-Packed Data)\n# ==========================================\ndef auto_discover_dataset(base_path):\n    print(f\"🔍 Scanning your optimized dataset at '{base_path}'...\")\n    exts = ('*.jpg', '*.jpeg', '*.png')\n    image_paths = []\n    \n    for ext in exts:\n        image_paths.extend(glob.glob(os.path.join(base_path, '**', ext), recursive=True))\n                \n    if not image_paths:\n        raise ValueError(f\"❌ No images found in {base_path}. Did you paste the correct dataset path?\")\n\n    print(f\"✅ Fast scan complete! Total images found: {len(image_paths)}\")\n    \n    labels = [os.path.basename(os.path.dirname(p)) for p in image_paths]\n    \n    TPUConfig.CLASS_NAMES = sorted(list(set(labels)))\n    TPUConfig.NUM_CLASSES = len(TPUConfig.CLASS_NAMES)\n    class_to_idx = {c: i for i, c in enumerate(TPUConfig.CLASS_NAMES)}\n    int_labels = [class_to_idx[l] for l in labels]\n    \n    counts = Counter(int_labels)\n    total = sum(counts.values())\n    weights = [total / counts[i] for i in range(TPUConfig.NUM_CLASSES)]\n    weight_sum = sum(weights)\n    TPUConfig.CLASS_WEIGHTS = [w / weight_sum * TPUConfig.NUM_CLASSES for w in weights]\n    \n    print(f\"✅ Found {TPUConfig.NUM_CLASSES} unique disease classes.\")\n    \n    train_paths, val_paths, train_labels, val_labels = train_test_split(\n        image_paths, int_labels, test_size=0.15, stratify=int_labels, random_state=TPUConfig.SEED\n    )\n    \n    return train_paths, val_paths, train_labels, val_labels\n\n# ==========================================\n# DATA PIPELINE & MODEL DEFINITION\n# ==========================================\nclass AutoImageDataset(Dataset):\n    def __init__(self, file_paths, labels, transform=None):\n        self.file_paths = file_paths\n        self.labels = labels\n        self.transform = transform\n\n    def __len__(self): return len(self.file_paths)\n\n    def __getitem__(self, idx):\n        img = Image.open(self.file_paths[idx]).convert('RGB')\n        if self.transform: img = self.transform(img)\n        return img, self.labels[idx]\n\ndef get_transforms():\n    # Because images are already 224x224, these transforms are lightning fast\n    train_transform = v2.Compose([\n        v2.RandomHorizontalFlip(p=0.5),\n        v2.RandomVerticalFlip(p=0.5),\n        v2.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2, hue=0.1),\n        v2.ToImage(), v2.ToDtype(torch.float32, scale=True),\n        v2.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),\n        v2.RandomErasing(p=0.2, scale=(0.02, 0.1))\n    ])\n    \n    val_transform = v2.Compose([\n        v2.ToImage(), v2.ToDtype(torch.float32, scale=True),\n        v2.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n    ])\n    return train_transform, val_transform\n\ndef build_dataloaders(train_paths, val_paths, train_labels, val_labels):\n    train_tfm, val_tfm = get_transforms()\n    train_dataset = AutoImageDataset(train_paths, train_labels, transform=train_tfm)\n    val_dataset = AutoImageDataset(val_paths, val_labels, transform=val_tfm)\n\n    train_sampler = torch.utils.data.distributed.DistributedSampler(\n        train_dataset, num_replicas=xm.xrt_world_size(), rank=xm.get_ordinal(), shuffle=True, drop_last=True)\n    val_sampler = torch.utils.data.distributed.DistributedSampler(\n        val_dataset, num_replicas=xm.xrt_world_size(), rank=xm.get_ordinal(), shuffle=False, drop_last=True)\n\n    train_loader = DataLoader(train_dataset, batch_size=TPUConfig.BATCH_SIZE_PER_CORE, sampler=train_sampler, num_workers=4, drop_last=True, pin_memory=True)\n    val_loader = DataLoader(val_dataset, batch_size=TPUConfig.BATCH_SIZE_PER_CORE, sampler=val_sampler, num_workers=4, drop_last=True, pin_memory=True)\n    return train_loader, val_loader\n\nclass PlantDiseaseModel(nn.Module):\n    def __init__(self, backbone_name='convnext_base', pretrained=True):\n        super().__init__()\n        self.backbone = timm.create_model(backbone_name, pretrained=pretrained, num_classes=0)\n        self.head = nn.Sequential(nn.Dropout(0.3), nn.Linear(self.backbone.num_features, TPUConfig.NUM_CLASSES))\n        \n    def forward(self, x): return self.head(self.backbone(x))\n\ndef set_backbone_trainable(model, trainable):\n    for param in model.backbone.parameters(): param.requires_grad = trainable\n\n# ==========================================\n# TPU TRAINING LOOP\n# ==========================================\ndef train_model(index, train_paths, val_paths, train_labels, val_labels):\n    device = xm.xla_device()\n    seed_everything(TPUConfig.SEED + index)\n    \n    model = PlantDiseaseModel('convnext_base').to(device)\n    weights = torch.tensor(TPUConfig.CLASS_WEIGHTS, dtype=torch.float32).to(device)\n    criterion = nn.CrossEntropyLoss(weight=weights, label_smoothing=TPUConfig.LABEL_SMOOTHING)\n    \n    optimizer = optim.AdamW(model.parameters(), lr=TPUConfig.SCALED_LR, weight_decay=TPUConfig.WEIGHT_DECAY)\n    scheduler = optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=TPUConfig.TOTAL_EPOCHS, T_mult=1, eta_min=1e-6)\n    \n    start_epoch = 0\n    checkpoint_path = os.path.join(TPUConfig.CHECKPOINT_DIR, \"v5e_latest_checkpoint.pth\")\n    if os.path.exists(checkpoint_path):\n        checkpoint = torch.load(checkpoint_path, map_location='cpu')\n        model.load_state_dict(checkpoint['model_state'])\n        optimizer.load_state_dict(checkpoint['optimizer_state'])\n        scheduler.load_state_dict(checkpoint['scheduler_state'])\n        start_epoch = checkpoint['epoch'] + 1\n        xm.master_print(f\"🔄 Resuming from epoch {start_epoch}\")\n    \n    train_loader, val_loader = build_dataloaders(train_paths, val_paths, train_labels, val_labels)\n    \n    for epoch in range(start_epoch, TPUConfig.TOTAL_EPOCHS):\n        if epoch < TPUConfig.EPOCHS_PHASE_1:\n            set_backbone_trainable(model, False)\n            if epoch == start_epoch: xm.master_print(\"❄️ Phase 1: Backbone Frozen (Training Head Only)\")\n        else:\n            set_backbone_trainable(model, True)\n            if epoch == TPUConfig.EPOCHS_PHASE_1: xm.master_print(\"🔥 Phase 2: Backbone Unfrozen (Full Fine-Tuning)\")\n\n        model.train()\n        tracker = xm.RateTracker()\n        train_device_loader = pl.MpDeviceLoader(train_loader, device)\n        \n        for step, (inputs, targets) in enumerate(train_device_loader):\n            optimizer.zero_grad()\n            with torch.autocast(device_type='xla', dtype=torch.bfloat16):\n                outputs = model(inputs)\n                loss = criterion(outputs, targets)\n                \n            loss.backward()\n            torch.nn.utils.clip_grad_norm_(model.parameters(), TPUConfig.MAX_GRAD_NORM)\n            xm.optimizer_step(optimizer)\n            tracker.add(TPUConfig.BATCH_SIZE_PER_CORE)\n            \n        scheduler.step()\n        \n        model.eval()\n        val_device_loader = pl.MpDeviceLoader(val_loader, device)\n        correct, total = 0, 0\n        \n        with torch.no_grad():\n            for inputs, targets in val_device_loader:\n                with torch.autocast(device_type='xla', dtype=torch.bfloat16):\n                    outputs = model(inputs)\n                _, predicted = torch.max(outputs.data, 1)\n                total += targets.size(0)\n                correct += (predicted == targets).sum().item()\n                \n        correct = xm.mesh_reduce('val_correct', correct, sum)\n        total = xm.mesh_reduce('val_total', total, sum)\n        accuracy = correct / total\n        \n        xm.master_print(f\"📈 Epoch {epoch} | Speed: {tracker.rate():.2f} imgs/sec | Val Acc: {accuracy:.4f}\")\n        \n        xm.rendezvous('save_checkpoint')\n        if xm.is_master_ordinal():\n            torch.save({\n                'epoch': epoch, 'model_state': model.state_dict(),\n                'optimizer_state': optimizer.state_dict(), 'scheduler_state': scheduler.state_dict(),\n                'class_names': TPUConfig.CLASS_NAMES \n            }, checkpoint_path)\n\nprint(\"✅ Blueprints loaded. Ready to run Cell 2!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-16T19:44:41.642467Z","iopub.execute_input":"2026-05-16T19:44:41.642711Z","iopub.status.idle":"2026-05-16T19:45:53.700410Z","shell.execute_reply.started":"2026-05-16T19:44:41.642693Z","shell.execute_reply":"2026-05-16T19:45:53.699204Z"},"jupyter":{"source_hidden":true}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"if __name__ == '__main__':\n    print(\"🚀 CELL 2 STARTED: Initiating sequence...\")\n    try:\n        # Step 1: Scan the optimized data\n        t_paths, v_paths, t_labels, v_labels = auto_discover_dataset(TPUConfig.INPUT_DIR)\n        \n        print(\"\\n⚡ Waking up all 8 TPU v5e Cores...\")\n        print(\"⏳ (It takes about 30-60 seconds for the TPU to compile the graph for the first time. Please wait...)\")\n        \n        # Step 2: Hand the data over to the TPU and start training\n        xmp.spawn(\n            train_model, \n            args=(t_paths, v_paths, t_labels, v_labels), \n            nprocs=TPUConfig.NUM_CORES, \n            start_method='fork'\n        )\n        \n        print(\"\\n🎉 Training Complete! Models are saved to:\", TPUConfig.CHECKPOINT_DIR)\n        \n    except ValueError as e:\n        print(f\"\\n❌ DATA ERROR: {e}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-16T19:46:01.178597Z","iopub.execute_input":"2026-05-16T19:46:01.179178Z","iopub.status.idle":"2026-05-16T19:46:01.185190Z","shell.execute_reply.started":"2026-05-16T19:46:01.179154Z","shell.execute_reply":"2026-05-16T19:46:01.184252Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import shutil\nimport os\n\nprint(\"Unzipping your optimized dataset... (This will take a few seconds)\")\n\n# Unzip the file into a new folder called 'my_dataset'\nshutil.unpack_archive(\"/kaggle/working/optimized_plant_data.zip\", \"/kaggle/working/my_dataset\")\n\nprint(\"✅ Unzipped successfully! Data is ready.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-16T19:47:18.962753Z","iopub.execute_input":"2026-05-16T19:47:18.963109Z","iopub.status.idle":"2026-05-16T19:47:19.153434Z","shell.execute_reply.started":"2026-05-16T19:47:18.963077Z","shell.execute_reply":"2026-05-16T19:47:19.152212Z"}},"outputs":[],"execution_count":null}]}